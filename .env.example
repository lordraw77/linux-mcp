# ─── Server 1 – accesso root via password ────────────────────────────────────
SERVER_1_LABEL=web-server
SERVER_1_HOST=192.168.1.10
SERVER_1_PORT=22
SERVER_1_USER=root
SERVER_1_PASSWORD=secret
# SERVER_1_KEY_PATH=/home/user/.ssh/id_rsa   # alternativa a PASSWORD
# SERVER_1_SUDO_PASSWORD=                    # non serve se USER=root

# ─── Server 2 – utente non privilegiato + sudo ───────────────────────────────
SERVER_2_LABEL=db-server
SERVER_2_HOST=192.168.1.20
SERVER_2_PORT=22
SERVER_2_USER=deploy
SERVER_2_PASSWORD=
SERVER_2_KEY_PATH=/home/user/.ssh/deploy_rsa
SERVER_2_SUDO_PASSWORD=deploy_sudo_pass     # usata per i comandi con use_sudo=true

# ─── Server 3 – altro host ───────────────────────────────────────────────────
# SERVER_3_LABEL=backup
# SERVER_3_HOST=10.0.0.5
# SERVER_3_PORT=2222
# SERVER_3_USER=admin
# SERVER_3_KEY_PATH=/root/.ssh/id_ed25519
# SERVER_3_SUDO_PASSWORD=admin_pass

# Aggiungere SERVER_N_* per quanti server si vuole; il loader si ferma al primo N mancante.

# ═══════════════════════════════════════════════════════════════════════════════
# AGENT – provider e modello di default
# ═══════════════════════════════════════════════════════════════════════════════
# Seleziona il provider attivo (openrouter|groq|gemini|cloudflare|cerebras|mistral|ollama)
AGENT_PROVIDER=openrouter
# Modello globale (sovrascrive il default del provider)
# AGENT_MODEL=

# ─── OpenRouter ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_DEFAULT_MODEL=openrouter/auto

# ─── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
# GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# ─── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
# GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# ─── Cloudflare Workers AI ────────────────────────────────────────────────────
CLOUDFLARE_API_KEY=...
CLOUDFLARE_ACCOUNT_ID=...
# CLOUDFLARE_DEFAULT_MODEL=@cf/meta/llama-3.1-8b-instruct

# ─── Cerebras ─────────────────────────────────────────────────────────────────
CEREBRAS_API_KEY=csk-...
# CEREBRAS_DEFAULT_MODEL=llama-3.3-70b

# ─── Mistral ──────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=...
# MISTRAL_DEFAULT_MODEL=mistral-small-latest

# ─── Ollama (locale, nessuna API key) ─────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_DEFAULT_MODEL=llama3.2
