# ─── Server 1 – accesso root via password ────────────────────────────────────
UXMCP_SERVER_1_LABEL=web-server
UXMCP_SERVER_1_HOST=192.168.1.10
UXMCP_SERVER_1_PORT=22
UXMCP_SERVER_1_USER=root
UXMCP_SERVER_1_PASSWORD=secret
# UXMCP_SERVER_1_KEY_PATH=/home/user/.ssh/id_rsa   # alternativa a PASSWORD
# UXMCP_SERVER_1_SUDO_PASSWORD=                    # non serve se USER=root

# ─── Server 2 – utente non privilegiato + sudo ───────────────────────────────
UXMCP_SERVER_2_LABEL=db-server
UXMCP_SERVER_2_HOST=192.168.1.20
UXMCP_SERVER_2_PORT=22
UXMCP_SERVER_2_USER=deploy
UXMCP_SERVER_2_PASSWORD=
UXMCP_SERVER_2_KEY_PATH=/home/user/.ssh/deploy_rsa
UXMCP_SERVER_2_SUDO_PASSWORD=deploy_sudo_pass     # usata per i comandi con use_sudo=true

# ─── Server 3 – altro host ───────────────────────────────────────────────────
# UXMCP_SERVER_3_LABEL=backup
# UXMCP_SERVER_3_HOST=10.0.0.5
# UXMCP_SERVER_3_PORT=2222
# UXMCP_SERVER_3_USER=admin
# UXMCP_SERVER_3_KEY_PATH=/root/.ssh/id_ed25519
# UXMCP_SERVER_3_SUDO_PASSWORD=admin_pass

# Aggiungere UXMCP_SERVER_N_* per quanti server si vuole; il loader si ferma al primo N mancante.

# ═══════════════════════════════════════════════════════════════════════════════
# AGENT – provider e modello di default
# ═══════════════════════════════════════════════════════════════════════════════
# Seleziona il provider attivo (openrouter|groq|gemini|cloudflare|cerebras|mistral|ollama)
UXMCP_AGENT_PROVIDER=openrouter
# Modello globale (sovrascrive il default del provider)
# UXMCP_AGENT_MODEL=

# ─── OpenRouter ───────────────────────────────────────────────────────────────
UXMCP_OPENROUTER_API_KEY=sk-or-...
# UXMCP_OPENROUTER_DEFAULT_MODEL=openrouter/auto

# ─── Groq ─────────────────────────────────────────────────────────────────────
UXMCP_GROQ_API_KEY=gsk_...
# UXMCP_GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# ─── Google Gemini ────────────────────────────────────────────────────────────
UXMCP_GEMINI_API_KEY=AIza...
# UXMCP_GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# ─── Cloudflare Workers AI ────────────────────────────────────────────────────
UXMCP_CLOUDFLARE_API_KEY=...
UXMCP_CLOUDFLARE_ACCOUNT_ID=...
# UXMCP_CLOUDFLARE_DEFAULT_MODEL=@cf/meta/llama-3.1-8b-instruct

# ─── Cerebras ─────────────────────────────────────────────────────────────────
UXMCP_CEREBRAS_API_KEY=csk-...
# UXMCP_CEREBRAS_DEFAULT_MODEL=llama-3.3-70b

# ─── Mistral ──────────────────────────────────────────────────────────────────
UXMCP_MISTRAL_API_KEY=...
# UXMCP_MISTRAL_DEFAULT_MODEL=mistral-small-latest

# ─── Ollama (locale, nessuna API key) ─────────────────────────────────────────
# UXMCP_OLLAMA_BASE_URL=http://localhost:11434/v1
# UXMCP_OLLAMA_DEFAULT_MODEL=llama3.2

# ═══════════════════════════════════════════════════════════════════════════════
# MCP DOCKER – server MCP containerizzato
# ═══════════════════════════════════════════════════════════════════════════════
# Immagine Docker del server MCP (usata con --mcp-docker senza argomento)
# UXMCP_MCP_DOCKER_IMAGE=lordraw/linux-mcp:latest
# Directory chiavi SSH montata nel container
# UXMCP_MCP_SSH_KEY_DIR=~/.ssh
